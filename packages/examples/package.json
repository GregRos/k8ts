{
  "name": "@k8ts/examples",
  "version": "0.1.0",
  "private": true,
  "description": "Examples for k8ts packages",
  "author": "GregRos",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index",
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -b .",
    "clean": "shx rm -rf dist",
    "build:clean": "run-s clean build",
    "tidy": "yarn install && run-s build:clean",
    "publish-locally": "node tools/publish-locally.js",
    "lint:fix": "prettier --write examples/**/*.{js,jsx,cjs,mjs,ts,tsx,cts,mts,ctsx,mtsx,html,htm,yaml,yml,json,scss,css} && eslint --fix examples/**/*.{ts,mts,cts,js,mjs,cjs}",
    "lint:check": "prettier --check examples/**/*.{js,jsx,cjs,mjs,ts,tsx,cts,mts,ctsx,mtsx,html,htm,yaml,yml,json,scss,css} && eslint examples/**/*.{ts,mts,cts,js,mjs,cjs}"
  },
  "dependencies": {
    "@k8ts/instruments": "file:.lib/@k8ts-instruments.tgz",
    "@k8ts/metadata": "file:.lib/@k8ts-metadata.tgz",
    "doddle": "^7.3.1",
    "k8ts": "file:.lib/k8ts.tgz",
    "yamprint": "^0.8.4"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.15",
    "@types/node": "^22.12.0",
    "lodash": "^4.17.21",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "prettier-plugin-jsdoc": "^1.3.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-packagejson": "^2.5.8",
    "shx": "^0.3.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "yarn@4.12.0",
  "sourcesRoot": "examples"
}
